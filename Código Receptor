#include <Adafruit_GFX.h>
#include <Adafruit_ST7789.h>
#include <esp_now.h>
#include <WiFi.h>

#define LCD_BLK 32
Adafruit_ST7789 tft = Adafruit_ST7789(15, 2, 4);

float dRec = -1;
int barrasAnteriores = -1;

void OnDataRecv(const uint8_t * mac, const uint8_t *data, int len) {
  memcpy(&dRec, data, sizeof(dRec));
}

void setup() {
  pinMode(LCD_BLK, OUTPUT);
  tft.init(135, 240); tft.setRotation(1);
  tft.fillScreen(ST77XX_BLACK);
  
  WiFi.mode(WIFI_STA);
  esp_now_init();
  esp_now_register_recv_cb(esp_now_recv_cb_t(OnDataRecv));

  tft.setCursor(60, 5); tft.setTextSize(2);
  tft.setTextColor(ST77XX_WHITE);
  tft.print("MANOBRA");
}

void loop() {
  if (dRec > 0 && dRec < 30) {
    digitalWrite(LCD_BLK, HIGH);
    
    int barrasAtuais = map(constrain(dRec, 2, 25), 2, 25, 10, 1);

    // SÓ REDESENHA SE AS BARRAS MUDAREM
    if (barrasAtuais != barrasAnteriores) {
      for (int i = 0; i < 10; i++) {
        uint16_t cor = (i < 4) ? ST77XX_GREEN : (i < 7) ? ST77XX_YELLOW : ST77XX_RED;
        int x = 15 + (i * 22);
        
        if (i < barrasAtuais) {
          tft.fillRect(x, 40, 18, 80, cor); // Desenha barra cheia
        } else {
          tft.fillRect(x, 40, 18, 80, ST77XX_BLACK); // Apaga barra
          tft.drawRect(x, 40, 18, 80, 0x3186); // Mantém moldura cinza
        }
      }
      barrasAnteriores = barrasAtuais;
    }
  } else {
    digitalWrite(LCD_BLK, LOW);
    barrasAnteriores = -1; // Reset para quando voltar a ligar
  }
  delay(30);
}
