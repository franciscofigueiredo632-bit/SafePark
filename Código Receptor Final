#include <Adafruit_GFX.h>       // Biblioteca base para rotinas gráficas da Adafruit
#include <Adafruit_ST7789.h>    // Biblioteca de controlo do ecrã LCD ST7789 integrado na Ideaspark
#include <esp_now.h>            // Biblioteca para receber dados via rádio pelo protocolo ESP-NOW
#include <WiFi.h>               // Biblioteca necessária para gerir o hardware de comunicação sem fios

#define LCD_BLK 32 // Pino de controlo do Backlight (Luz de fundo) do ecrã do painel

// Inicialização do ecrã usando a mesma pinagem do display da Ideaspark (Pins: CS=15, DC=2, RST=4)
Adafruit_ST7789 tft = Adafruit_ST7789(15, 2, 4);

float dRec = -1;           // Variável global que armazena a última distância recebida do exterior
int barrasAnteriores = -1; // Memória técnica para guardar o número de barras desenhado no ciclo anterior

// Função de Callback executada automaticamente sempre que novos dados chegam pelo ar via ESP-NOW
void OnDataRecv(const uint8_t * mac, const uint8_t *data, int len) {
  memcpy(&dRec, data, sizeof(dRec)); // Copia de forma segura os dados brutos recebidos para a variável dRec
}

void setup() {
  pinMode(LCD_BLK, OUTPUT); // Configura o pino de luz de fundo do LCD como saída de sinal
  
  // Inicialização física da interface visual
  tft.init(135, 240);          // Configura a matriz gráfica do display para 135x240 píxeis
  tft.setRotation(1);          // Aplica rotação de 90 graus (Modo paisagem horizontal)
  tft.fillScreen(ST77XX_BLACK); // Preenche o fundo com a cor preta absoluta
  
  // Inicialização do recetor de rádio
  WiFi.mode(WIFI_STA);         // Coloca o módulo de Wi-Fi no modo Estação necessário para o protocolo
  esp_now_init();              // Ativa o motor do protocolo de baixa latência ESP-NOW
  esp_now_register_recv_cb(esp_now_recv_cb_t(OnDataRecv)); // Associa a função OnDataRecv à chegada de novas mensagens

  // Desenha o título fixo do painel uma única vez para otimizar desempenho e evitar tremuras
  tft.setCursor(60, 5); tft.setTextSize(2);
  tft.setTextColor(ST77XX_WHITE);
  tft.print("MANOBRA");
}

// Função responsável por gerir e desenhar o gráfico de barras dinâmico
void drawBars(float d) {
  // Mapeia e calcula quantas barras devem acender (Inverso: Distância curta = Mais barras ativas)
  // Converte a faixa de manobra útil de 2cm a 25cm na escala de 10 a 1 barras visíveis
  int barrasAtuais = map(constrain(d, 2, 25), 2, 25, 10, 1);

  // Lógica de Redesenho Seletivo: Só redesenha as barras se houve mudança na escala real de barras
  if (barrasAtuais != barrasAnteriores) {
    for (int i = 0; i < 10; i++) {
      // Define a cor de cada segmento com base na sua posição (Estilo Sensor de Fábrica)
      // Barras 0 a 3: Verde | Barras 4 a 6: Amarelo | Barras 7 a 9: Vermelho
      uint16_t cor = (i < 4) ? ST77XX_GREEN : (i < 7) ? ST77XX_YELLOW : ST77XX_RED;
      int x = 15 + (i * 22); // Calcula a coordenada X de cada retângulo aplicando um espaçamento fixo de 22 píxeis
      
      if (i < barrasAtuais) {
        tft.fillRect(x, 40, 18, 80, cor); // Desenha o bloco preenchido com a cor de aviso correspondente
      } else {
        tft.fillRect(x, 40, 18, 80, ST77XX_BLACK); // Limpa e apaga a barra escrevendo preto por cima
        tft.drawRect(x, 40, 18, 80, 0x3186);       // Desenha uma moldura vazia em cinzento escuro no lugar do bloco apagado
      }
    }
    barrasAnteriores = barrasAtuais; // Guarda o estado gráfico atual para a próxima comparação
  }
}

void loop() {
  // Verifica as condições de ativação: Deve haver dados válidos (>0) e dentro da zona ativa de manobra (<30cm)
  if (dRec > 0 && dRec < 30) {
    digitalWrite(LCD_BLK, HIGH); // Ativa o brilho do ecrã interior caso estivesse apagado
    drawBars(dRec);              // Executa a atualização gráfica da escala de barras no painel
  } else {
    // Se o carro estiver parado perto por inatividade (recebeu -1) ou se estiver livre de obstáculos (>30cm)
    digitalWrite(LCD_BLK, LOW);  // Apaga completamente a tela do painel interno do carro
    barrasAnteriores = -1;       // Faz o reset da memória das barras para forçar atualização no próximo arranque
  }
  delay(30); // Ritmo de atualização visual rápido e fluido de cerca de 30 milissegundos
}
